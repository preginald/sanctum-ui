# Sanctum UI — Environment Variables
# Copy this file to .env and adjust values as needed.
#
# This is a component library — no secrets or API keys are required
# for local development.

# Storybook port (optional, defaults to 6006)
# STORYBOOK_PORT=6006

# Vite dev server port (optional, defaults to 5173)
# VITE_PORT=5173
